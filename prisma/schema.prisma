// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String
  role      String     @default("OPERATOR") // ADMIN or OPERATOR
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  logs      AuditLog[]
  repeaters Repeater[] @relation("RepeaterUpdater")
  accounts  Account[]
  sessions  Session[]
}

model Mine {
  id                  String    @id @default(cuid())
  syncId              String    @unique @default(cuid())
  name                String
  description         String?
  imageUrl            String
  opacity             Float     @default(1.0)
  centerLat           Float     @default(-19.8157)
  centerLng           Float     @default(-43.9542)
  defaultZoom         Int       @default(14)
  coordinateSystem    String    @default("WGS84")
  imageBounds         Json?     // Bounding box: [[lat, lng], [lat, lng]]
  boundaryCoordinates Json?     // Perimeter coordinates: [[lat, lng], [lat, lng], ...]
  
  // Heatmap configuration per mine
  heatRadius    Int   @default(60)
  heatBlur      Int   @default(40)
  heatIntensity Float @default(0.8)
  
  // Grid resolution (20, 40, 80, 120)
  gridResolution Int @default(40)
  
  calibrationAccuracy Float?
  isCalibrated        Boolean @default(false)

  // Terrain elevation integration parameters
  terrainEnabled      Boolean @default(false)
  terrainSource       String?
  terrainResolution   Int?

  version   Int       @default(1)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repeaters   Repeater[]
  obstacles   Obstacle[]
  auditLogs   AuditLog[]
}

model Repeater {
  id                  String   @id @default(cuid())
  syncId              String   @unique @default(cuid())
  name                String
  code                String   @unique
  model               String
  status              String   @default("OFFLINE") // ONLINE, OFFLINE, MAINTENANCE
  notes               String?
  latitude            Float?
  longitude           Float?
  altitude            Float?   // Optional altitude for 3D/terrain support
  locationDescription String?
  range               Float    @default(100) // coverage radius in meters
  
  mineId String
  mine   Mine   @relation(fields: [mineId], references: [id], onDelete: Cascade)

  updatedById String?
  updatedBy   User?    @relation("RepeaterUpdater", fields: [updatedById], references: [id])
  
  version   Int       @default(1)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Obstacle {
  id          String   @id @default(cuid())
  syncId      String   @unique @default(cuid())
  name        String
  type        String   @default("SLOPE") // SLOPE (talude), WALL (paredão), PILE (leira)
  coordinates Json     // Store coordinates as native JSON array: [[lat, lng], ...]
  attenuation Float    @default(0.5) // Signal attenuation coefficient (0.0 to 1.0)
  
  mineId String
  mine   Mine   @relation(fields: [mineId], references: [id], onDelete: Cascade)

  version   Int       @default(1)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  oldValues Json?    // Previous state values in JSON format
  newValues Json?    // New state values in JSON format
  ip        String?
  
  userId String?
  user   User?   @relation(fields: [userId], references: [id])
  
  mineId String?
  mine   Mine?   @relation(fields: [mineId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
